+@Composable
+private fun SummaryMetricGrid(summary: ReportSummary) {
+    val accuracyRateLabel =
+        summary.performance.accuracyRate
+            .coerceIn(
+                PERCENT_MIN,
+                PERCENT_MAX,
+            ).toInt()

+        createdAtMillis = createdAtMillis,
+        updatedAtMillis = updatedAtMillis,
+        lastFailureMessage = lastFailureMessage,
+    )
+
+fun PendingLearningQuizAnswerSubmission.toEntity(): PendingLearningQuizAnswerSubmissionEntity =

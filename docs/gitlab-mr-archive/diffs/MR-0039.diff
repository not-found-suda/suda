+
+def get_next_model_path() -> str:
+    """models/ 폴더에서 sign_lstm_N.pt 중 가장 높은 N을 찾아 N+1 경로를 반환합니다."""
+    os.makedirs(MODEL_DIR, exist_ok=True)

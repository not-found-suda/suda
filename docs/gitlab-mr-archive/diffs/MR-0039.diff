+class EarlyStopping:
+    def __init__(self, patience: int = 20, delta: float = 1e-4):
+        self.patience  = patience
+        self.delta     = delta
+        self.counter   = 0
+        self.best_loss = float("inf")
+        self.triggered = False
+
+    def step(self, val_loss: float) -> bool:
+        if val_loss < self.best_loss - self.delta:

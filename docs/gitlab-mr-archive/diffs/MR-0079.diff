diff --git a/backend/src/main/resources/db/migration/V20260506210000__backfill_learn_category_id.sql b/backend/src/main/resources/db/migration/V20260506210000__backfill_learn_category_id.sql
--- /dev/null
+++ b/backend/src/main/resources/db/migration/V20260506210000__backfill_learn_category_id.sql
@@ -0,0 +1,16 @@
+ALTER TABLE learn
+  ALTER COLUMN category_id SET NOT NULL;
+
+DO $$
+BEGIN
+    IF NOT EXISTS (
+        SELECT 1
+        FROM pg_constraint
+        WHERE conname = 'fk_learn_category'
+    ) THEN
+ALTER TABLE learn
+  ADD CONSTRAINT fk_learn_category
+    FOREIGN KEY (category_id)
+      REFERENCES learn_categories(id);
+END IF;
+END $$;



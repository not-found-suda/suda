+                fontWeight = FontWeight.Bold,
+                modifier = Modifier.weight(1f),
+                maxLines = 1,
+            )
+            TextButton(
+                onClick = onNextClick,
+                enabled = currentPage < totalPages - 1,
+            ) {
+                Text(text = "다음")
+            }
+        }
+    }

diff --git a/.gitlab/scripts/setup-android-sdk.sh b/.gitlab/scripts/setup-android-sdk.sh
--- a/.gitlab/scripts/setup-android-sdk.sh
+++ b/.gitlab/scripts/setup-android-sdk.sh
@@ -6,8 +6,8 @@ set -euo pipefail
 : "${ANDROID_COMPILE_SDK:?ANDROID_COMPILE_SDK is required}"
 : "${ANDROID_BUILD_TOOLS:?ANDROID_BUILD_TOOLS is required}"
 
-apt-get update -y
-apt-get install -y curl unzip
+apt-get update -qq
+DEBIAN_FRONTEND=noninteractive apt-get install -y -qq --no-install-recommends curl unzip >/dev/null
 
 echo "[setup-android-sdk] preparing cmdline-tools directory"
 mkdir -p "${ANDROID_SDK_ROOT}/cmdline-tools"
@@ -24,12 +24,19 @@ export PATH="${ANDROID_SDK_ROOT}/cmdline-tools/latest/bin:${ANDROID_SDK_ROOT}/pl
 
 echo "[setup-android-sdk] accepting Android SDK licenses"
 set +o pipefail
-yes | sdkmanager --licenses >/dev/null
+yes | sdkmanager --licenses >/dev/null 2>&1
 set -o pipefail
 
 echo "[setup-android-sdk] installing SDK packages"
-sdkmanager --install \
+if ! sdkmanager --install \
   --sdk_root="${ANDROID_SDK_ROOT}" \
   "platform-tools" \
   "platforms;android-${ANDROID_COMPILE_SDK}" \
-  "build-tools;${ANDROID_BUILD_TOOLS}"
+  "build-tools;${ANDROID_BUILD_TOOLS}" \
+  >/tmp/android-sdk-install.log 2>&1; then
+  echo "[setup-android-sdk] sdkmanager install failed. last 200 lines:"
+  tail -n 200 /tmp/android-sdk-install.log
+  exit 1
+fi
+
+rm -f /tmp/android-sdk-install.log


diff --git a/.gitlab-ci.yml b/.gitlab-ci.yml
--- a/.gitlab-ci.yml
+++ b/.gitlab-ci.yml
@@ -92,12 +92,8 @@ mobile-check:
     - cd mobile
     - chmod +x gradlew
   script:
-    - echo "[mobile-check] step 1/3 - ktlintCheck + detekt"
-    - ./gradlew ktlintCheck detekt --no-daemon --console=plain --info
-    - echo "[mobile-check] step 2/3 - lintDebug"
-    - ./gradlew lintDebug --no-daemon --console=plain --info
-    - echo "[mobile-check] step 3/3 - testDebugUnitTest + assembleDebug"
-    - ./gradlew testDebugUnitTest assembleDebug --no-daemon --console=plain --info
+    - echo "[mobile-check] running quality gate (ktlint/detekt/lint/test/assemble)"
+    - ./gradlew ktlintCheck detekt lintDebug testDebugUnitTest assembleDebug --no-daemon --console=plain --warning-mode=summary
 
 secret-scan:
   stage: security



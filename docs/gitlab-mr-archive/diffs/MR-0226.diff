+
+    data class Final(
+        val recognizedText: String,
+        val correctedText: String,
+        val confidence: Double?,
+        val locale: String?,
+    ) : TranslationStreamingSttEvent
+
+    data class Error(
+        val message: String,
+        val cause: Throwable? = null,
+    ) : TranslationStreamingSttEvent
+
+    data object Closed : TranslationStreamingSttEvent
+}



+    verify(passwordResetStore, never()).saveResetToken(Mockito.any(), Mockito.any(), Mockito.any());
+  }
+
+  @Test
+  @DisplayName("인증 코드 실패 횟수가 제한에 도달하면 인증 코드를 삭제한다")
+  void verifyDeletesCodeWhenMaxAttemptsExceeded() {

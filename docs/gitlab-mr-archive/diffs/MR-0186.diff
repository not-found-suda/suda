+    verify(passwordResetCodeGenerator, never()).generateResetToken();
+    verify(passwordResetStore, never()).saveResetToken(Mockito.any(), Mockito.any(), Mockito.any());
+  }
+
+  @Test
+  @DisplayName("재설정 토큰이 유효하면 새 비밀번호를 저장하고 토큰을 무효화한다")

+      "AUTH_INVALID_REFRESH_TOKEN", HttpStatus.UNAUTHORIZED, "유효하지 않은 리프레시 토큰입니다."),
+  INACTIVE_ACCOUNT("AUTH_INACTIVE_ACCOUNT", HttpStatus.FORBIDDEN, "비활성화된 계정입니다."),

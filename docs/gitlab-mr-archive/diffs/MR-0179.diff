+    return wordCounts.entrySet().stream()
+        .sorted(Map.Entry.<String, Integer>comparingByValue(Comparator.reverseOrder()))
+        .limit(limit)
+        .map(entry -> new ReportWordCountResponse(entry.getKey(), entry.getValue()))
+        .toList();
+  }
+

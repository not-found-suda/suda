diff --git a/mobile/app/src/main/java/com/ssafy/mobile/feature/conversation/data/repository/DataStoreTranslationModeRepository.kt b/mobile/app/src/main/java/com/ssafy/mobile/feature/conversation/data/repository/DataStoreTranslationModeRepository.kt

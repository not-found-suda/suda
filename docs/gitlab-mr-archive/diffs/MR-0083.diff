+      invalid_timestamps=$(find backend/src/main/resources/db/migration -type f -name "V*.sql" -exec basename {} \; | awk '
+        function leap_year(year) {
+          return (year % 400 == 0) || (year % 4 == 0 && year % 100 != 0)
+        }
+
+        function valid_timestamp(timestamp) {
+          year = substr(timestamp, 1, 4) + 0
+          month = substr(timestamp, 5, 2) + 0
+          day = substr(timestamp, 7, 2) + 0
+          hour = substr(timestamp, 9, 2) + 0
+          minute = substr(timestamp, 11, 2) + 0
+          second = substr(timestamp, 13, 2) + 0
+
+          if (month < 1 || month > 12) return 0
+          if (hour < 0 || hour > 23) return 0
+          if (minute < 0 || minute > 59) return 0
+          if (second < 0 || second > 59) return 0
+
+          days_in_month[1] = 31
+          days_in_month[2] = leap_year(year) ? 29 : 28
+          days_in_month[3] = 31
+          days_in_month[4] = 30
+          days_in_month[5] = 31
+          days_in_month[6] = 30
+          days_in_month[7] = 31
+          days_in_month[8] = 31
+          days_in_month[9] = 30
+          days_in_month[10] = 31
+          days_in_month[11] = 30
+          days_in_month[12] = 31
+
+          return day >= 1 && day <= days_in_month[month]
+        }
+
+        {
+          timestamp = substr($0, 2, 14)
+          if (!valid_timestamp(timestamp)) print $0
+        }
+      ')
+
+      if [ -n "$invalid_timestamps" ]; then
+        echo "잘못된 Flyway 마이그레이션 timestamp:"
+        echo "$invalid_timestamps"

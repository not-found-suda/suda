diff --git a/frontend/src/features/auth/model/tokenStore.ts b/frontend/src/features/auth/model/tokenStore.ts
--- /dev/null
+++ b/frontend/src/features/auth/model/tokenStore.ts
@@ -0,0 +1,24 @@
+import type { TokenPair } from '@/features/auth/model/types'
+
+const ACCESS_TOKEN_KEY = 'auth.access_token'
+const REFRESH_TOKEN_KEY = 'auth.refresh_token'
+
+export function getAccessToken() {
+  return localStorage.getItem(ACCESS_TOKEN_KEY)
+}
+
+export function getRefreshToken() {
+  return localStorage.getItem(REFRESH_TOKEN_KEY)
+}
+
+export function setTokens({ accessToken, refreshToken }: TokenPair) {
+  localStorage.setItem(ACCESS_TOKEN_KEY, accessToken)
+  if (refreshToken) {
+    localStorage.setItem(REFRESH_TOKEN_KEY, refreshToken)
+  }
+}
+
+export function clearTokens() {
+  localStorage.removeItem(ACCESS_TOKEN_KEY)
+  localStorage.removeItem(REFRESH_TOKEN_KEY)
+}



+  { label: 'FAQ', to: ROUTES.faq },
+]
+
+function MainLayout() {
+  return (
+    <div className="min-h-screen bg-bg text-text-primary">
+      <header className="border-b border-border bg-surface">
+        <div className="mx-auto flex w-full max-w-5xl flex-col gap-4 px-4 py-5 md:px-6">

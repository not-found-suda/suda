diff --git a/docker-compose.ai.yml b/docker-compose.ai.yml
--- /dev/null
+++ b/docker-compose.ai.yml
@@ -0,0 +1,29 @@
+name: s14p31a404-ai
+
+services:
+  ai-server:
+    build:
+      context: ./ai
+      dockerfile: ai-server/Dockerfile
+    container_name: ai-server
+    environment:
+      TZ: Asia/Seoul
+      SIGN_MODEL_PATH: ${SIGN_MODEL_CONTAINER_PATH:-/models/best_sign_model_v6.pt}
+      SIGN_TRAIN_CONFIG_PATH: ${SIGN_TRAIN_CONFIG_CONTAINER_PATH:-/models/train_config_v6.json}
+      SIGN_LABEL_MAP_PATH: ${SIGN_LABEL_MAP_CONTAINER_PATH:-/models/label_map_v6.json}
+      SIGN_MODEL_MODULE_PATH: ${SIGN_MODEL_MODULE_CONTAINER_PATH:-/models/model.py}
+      SIGN_CONFIDENCE_THRESHOLD: ${SIGN_CONFIDENCE_THRESHOLD:-0.80}
+      SIGN_NONE_LABEL: ${SIGN_NONE_LABEL:-none}
+      SIGN_MODEL_VERSION: ${SIGN_MODEL_VERSION:-v6_24words_tcn}
+    volumes:
+      - ${SIGN_MODEL_ARTIFACT_PATH:-./ai/model-artifacts}:/models:ro
+    ports:
+      - "${AI_SERVER_BIND_HOST:-127.0.0.1}:${AI_SERVER_PORT:-8000}:8000"
+    gpus: all
+    healthcheck:
+      test: ["CMD-SHELL", "python -c \"import json, sys, urllib.request; data=json.load(urllib.request.urlopen('http://localhost:8000/health', timeout=2)); sys.exit(0 if data.get('modelLoaded') is True else 1)\""]
+      interval: 5s
+      timeout: 3s
+      retries: 20
+      start_period: 30s
+    restart: unless-stopped



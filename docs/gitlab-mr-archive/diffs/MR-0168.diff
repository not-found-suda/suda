+            onClick = { onInputChange(input.selectCurrentYear()) },
+            modifier =
+                Modifier
+                    .width(88.dp)
+                    .height(34.dp),
+            shape = RoundedCornerShape(8.dp),
+            contentPadding = PaddingValues(horizontal = 4.dp),

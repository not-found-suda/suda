diff --git a/mobile/app/src/main/java/com/ssafy/mobile/feature/mypage/presentation/AiModelSettingsRoute.kt b/mobile/app/src/main/java/com/ssafy/mobile/feature/mypage/presentation/AiModelSettingsRoute.kt

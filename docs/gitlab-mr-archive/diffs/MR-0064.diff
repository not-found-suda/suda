diff --git a/mobile/app/src/main/java/com/ssafy/mobile/feature/quiz/domain/model/QuizSessionReducer.kt b/mobile/app/src/main/java/com/ssafy/mobile/feature/quiz/domain/model/QuizSessionReducer.kt

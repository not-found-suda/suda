+
+@Composable
+private fun QuizAnswerResultItem(answer: LearningQuizResultAnswer) {
+    Card(
+        modifier = Modifier.fillMaxWidth(),
+        shape = RoundedCornerShape(20.dp),
+        colors =
+            CardDefaults.cardColors(

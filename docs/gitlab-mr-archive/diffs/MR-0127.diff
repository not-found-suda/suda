+
+@Composable
+private fun QuizAnswerStatusIcon(isCorrect: Boolean) {
+    Box(
+        modifier =
+            Modifier
+                .size(36.dp)
+                .clip(CircleShape)
+                .background(
+                    if (isCorrect) {
+                        MaterialTheme.colorScheme.primary.copy(alpha = 0.1f)
+                    } else {
+                        MaterialTheme.colorScheme.error.copy(alpha = 0.1f)
+                    },

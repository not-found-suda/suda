+                iconEmoji = "✅",
+            )
+            Box(
+                modifier =
+                    Modifier
+                        .width(1.dp)
+                        .height(40.dp)
+                        .background(
+                            MaterialTheme.colorScheme.onPrimaryContainer.copy(alpha = 0.1f),
+                        ),
+            )
+            ResultStatItem(
+                label = "획득한 별",
+                value = "$totalStar",
+                iconEmoji = "⭐",
+            )
+        }
+    }
+}
+
+@Composable
+private fun ResultStatItem(
+    label: String,

+import retrofit2.http.PATCH
+import retrofit2.http.POST
+import retrofit2.http.Path
+
+interface CommsSessionApiService {
+    @POST("v1/comms/sessions")
+    suspend fun createSession(
+        @Body request: CommsSessionCreateRequest,

+private fun ImageProxy.toUprightBitmap(): Bitmap {
+    val nv21 = toNv21()
+    val jpegBytes =
+        ByteArrayOutputStream().use { outputStream ->
+            YuvImage(
+                nv21,
+                ImageFormat.NV21,
+                width,
+                height,
+                null,
+            ).compressToJpeg(
+                Rect(0, 0, width, height),
+                JPEG_QUALITY,
+                outputStream,
+            )
+            outputStream.toByteArray()
+        }

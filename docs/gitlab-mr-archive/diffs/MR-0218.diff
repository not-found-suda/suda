diff --git a/mobile/app/src/main/java/com/ssafy/mobile/feature/conversation/data/streaming/OkHttpTranslationStreamingSttClient.kt b/mobile/app/src/main/java/com/ssafy/mobile/feature/conversation/data/streaming/OkHttpTranslationStreamingSttClient.kt

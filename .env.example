# Infrastructure (PostgreSQL / Redis)
POSTGRES_DB=appdb
POSTGRES_PORT=5432

# Backend runtime
SPRING_PROFILES_ACTIVE=dev
DB_URL=jdbc:postgresql://localhost:5432/appdb
DB_USERNAME=appuser
DB_PASSWORD=apppassword
AUTH_JWT_SECRET=change-this-dev-jwt-secret-at-least-32-bytes
AUTH_JWT_ISSUER=s14p31a404-dev
AUTH_ACCESS_TOKEN_TTL_SECONDS=900
AUTH_REFRESH_TOKEN_TTL_SECONDS=1209600
AUTH_REFRESH_COOKIE_NAME=refresh_token
AUTH_REFRESH_COOKIE_SECURE=false
AUTH_REFRESH_COOKIE_SAME_SITE=Lax
AUTH_REFRESH_COOKIE_PATH=/
SECURITY_CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:5173,http://127.0.0.1:5173

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redispassword

# App ports
BACKEND_PORT=8080
FRONTEND_PORT=5173

# Sign AI server
# 로컬에서 Spring을 직접 실행할 때는 SIGN_AI_BASE_URL을 사용합니다.
# Docker Compose backend는 BACKEND_SIGN_AI_BASE_URL을 사용합니다.
# 같은 compose의 local-ai profile을 쓰면 http://ai-server:8000,
# 원격 GPU AI 서버를 쓰면 http://<gpu-private-ip>:8000 형태로 설정합니다.
SIGN_AI_BASE_URL=http://localhost:8000
BACKEND_SIGN_AI_BASE_URL=http://ai-server:8000
SIGN_AI_CONNECT_TIMEOUT=1s
SIGN_AI_READ_TIMEOUT=1s
SIGN_MODEL_ARTIFACT_PATH=/absolute/path/to/sign-model-artifact
SIGN_MODEL_PATH=/absolute/path/to/sign-model-artifact/best_sign_model_v6.pt
SIGN_TRAIN_CONFIG_PATH=/absolute/path/to/sign-model-artifact/train_config_v6.json
SIGN_LABEL_MAP_PATH=/absolute/path/to/sign-model-artifact/label_map_v6.json
SIGN_MODEL_MODULE_PATH=/absolute/path/to/sign-model-artifact/model.py
SIGN_MODEL_CONTAINER_PATH=/models/best_sign_model_v6.pt
SIGN_TRAIN_CONFIG_CONTAINER_PATH=/models/train_config_v6.json
SIGN_LABEL_MAP_CONTAINER_PATH=/models/label_map_v6.json
SIGN_MODEL_MODULE_CONTAINER_PATH=/models/model.py
SIGN_CONFIDENCE_THRESHOLD=0.80
SIGN_NONE_LABEL=none
SIGN_MODEL_VERSION=v6_24words_tcn
# docker-compose.ai.yml로 GPU 서버에 단독 배포할 때 사용합니다.
# 다른 서버의 Spring에서 접근해야 하면 AI_SERVER_BIND_HOST=0.0.0.0으로 바꾸고 방화벽을 제한합니다.
AI_SERVER_BIND_HOST=127.0.0.1
AI_SERVER_PORT=8000

# Frontend (Vite)
VITE_API_BASE_URL=http://localhost:8080
VITE_API_TIMEOUT_MS=10000

# Gemini via GMS
GMS_KEY=your-gms-key
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_BASE_URL=https://gms.ssafy.io/gmsapi/generativelanguage.googleapis.com

# Clova common credentials
CLOVA_CLIENT_ID=your-clova-client-id
CLOVA_CLIENT_SECRET=your-clova-client-secret

# Clova TTS
CLOVA_TTS_URL=https://naveropenapi.apigw.ntruss.com/tts-premium/v1/tts
CLOVA_TTS_SPEAKER=nara
CLOVA_TTS_FORMAT=mp3

# Clova STT
CLOVA_STT_URL=https://naveropenapi.apigw.ntruss.com/recog/v1/stt
CLOVA_STT_LANGUAGE=Kor

# Clova Speech gRPC Streaming PoC
CLOVA_SPEECH_GRPC_ENDPOINT=clovaspeech-gw.ncloud.com:50051
CLOVA_SPEECH_SECRET_KEY=your-clova-speech-secret-key
CLOVA_SPEECH_LANGUAGE=ko
CLOVA_SPEECH_POC_ENABLED=false
CLOVA_SPEECH_POC_AUDIO_PATH=/absolute/path/to/16khz-mono-16bit-raw.pcm
CLOVA_SPEECH_POC_SKIP_WAV_HEADER=false

# Translation STT mode: REST, STREAMING, AUTO
TRANSLATION_STT_MODE=REST

# Naver OAuth
NAVER_CLIENT_ID=your-naver-client-id
NAVER_CLIENT_SECRET=your-naver-client-secret
NAVER_CLIENT_NAME=SUDA

# Mobile on-device sLLM model
SLLM_MODEL_DOWNLOAD_URL=https://d14zyw67949hvk.cloudfront.net/models/sllm/qwen2.5-1.5b/qwen2.5-1.5b.litertlm

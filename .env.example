# Infrastructure (PostgreSQL / Redis)
POSTGRES_DB=appdb
POSTGRES_PORT=5432

# Backend runtime
SPRING_PROFILES_ACTIVE=dev
DB_URL=jdbc:postgresql://localhost:5432/appdb
DB_USERNAME=appuser
DB_PASSWORD=apppassword
AUTH_JWT_SECRET=change-this-dev-jwt-secret-at-least-32-bytes
AUTH_JWT_ISSUER=s14p31a404-dev
AUTH_ACCESS_TOKEN_TTL_SECONDS=900
AUTH_REFRESH_TOKEN_TTL_SECONDS=1209600
AUTH_REFRESH_COOKIE_NAME=refresh_token
AUTH_REFRESH_COOKIE_SECURE=false
AUTH_REFRESH_COOKIE_SAME_SITE=Lax
AUTH_REFRESH_COOKIE_PATH=/
SECURITY_CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:5173,http://127.0.0.1:5173

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redispassword

# App ports
BACKEND_PORT=8080
FRONTEND_PORT=5173

# Sign AI server
SIGN_AI_BASE_URL=http://localhost:8000
SIGN_AI_CONNECT_TIMEOUT=1s
SIGN_AI_READ_TIMEOUT=1s

# Frontend (Vite)
VITE_API_BASE_URL=http://localhost:8080
VITE_API_TIMEOUT_MS=10000

# Gemini via GMS
GMS_KEY=your-gms-key
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_BASE_URL=https://gms.ssafy.io/gmsapi/generativelanguage.googleapis.com

# Clova common credentials
CLOVA_CLIENT_ID=your-clova-client-id
CLOVA_CLIENT_SECRET=your-clova-client-secret

# Clova TTS
CLOVA_TTS_URL=https://naveropenapi.apigw.ntruss.com/tts-premium/v1/tts
CLOVA_TTS_SPEAKER=nara
CLOVA_TTS_FORMAT=mp3

# Clova STT
CLOVA_STT_URL=https://naveropenapi.apigw.ntruss.com/recog/v1/stt
CLOVA_STT_LANGUAGE=Kor

# Naver OAuth
NAVER_CLIENT_ID=your-naver-client-id
NAVER_CLIENT_SECRET=your-naver-client-secret
NAVER_CLIENT_NAME=SUDA

# Mobile on-device sLLM model
SLLM_MODEL_DOWNLOAD_URL=https://d14zyw67949hvk.cloudfront.net/models/sllm/qwen2.5-1.5b/qwen2.5-1.5b.litertlm
